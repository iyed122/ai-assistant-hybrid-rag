# ═══════════════════════════════════════════════════════════════════════
#  AI Assistant — environment template
#  Copy to .env and fill in. Never commit .env.
# ═══════════════════════════════════════════════════════════════════════

# ── Neo4j (knowledge graph + vector index) ───────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j
EMBEDDING_DIM=768

# ── Embeddings & retrieval ───────────────────────────────────────────────
EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-m
SEARCH_TOP_K=10
GRAPH_HOPS=2
MAX_GRAPH_EXPAND=20
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_POOL=50
VEC_CANDIDATES=40
PARENT_DOC_CAP=3
GRAPH_MIN_SLOTS=0
GRAPH_MIN_RERANK=0.0
RERANK_TEXT_CHARS=800
GRAPH_DECAY=0.85

# ── LLM (local via Ollama) ───────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
MAX_TOKENS=1024
TEMPERATURE=0.2
NUM_CTX=8192

# ── Agent / weaver ───────────────────────────────────────────────────────
RAG_MIN_SCORE=0.20
RAG_MAX_SOURCES=6
RAG_TOP_K=8
GPU_CLEAR_EVERY_N=0
WEAVER_MAX_TOKENS=2010
WEAVER_TEMPERATURE=0.2
WEAVER_NUM_CTX=10240
WEAVER_RAG_CAP=6000
WEAVER_SENTRIES_CAP=12000
WEAVER_HISTORY_CHAR_CAP=300

# ── Live-API sentries (GitLab / Jira / Confluence) ───────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxx
GITLAB_OWNER=
GITLAB_PREFERRED_NAMESPACE=
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=xxxx
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=xxxx
SENTRY_FANOUT_MAX_GITLAB=12
SENTRY_FANOUT_MAX_JIRA=10
SENTRY_EXCLUDED_NAMESPACES=
AGENT_TEST_THREADSAFE_RL=0

# ── MongoDB (chat history + evaluation) ──────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=knowledge_base

# ── Hammer (evaluation & training-data pipeline) ─────────────────────────
HAMMER_RETRIEVAL_MISS_FAITH=0.50
HAMMER_RETRIEVAL_MISS_SRC=0.30
HAMMER_LATENCY_P95_SENTRIES=3.5
HAMMER_LATENCY_P95_RAG=5.0
HAMMER_LATENCY_P95_BOTH=7.0
GATE_MIN_FAITHFULNESS=0.80
GATE_MIN_SCORE_DELTA=0.005
GATE_MIN_SENTRIES_FAITH=0.75
GATE_ALLOW_EQUAL=false

# ── Training (QLoRA / DPO on consumer GPU) ───────────────────────────────
HF_MODEL_ID=unsloth/Qwen2.5-3B-Instruct-bnb-4bit
MLFLOW_EXPERIMENT=weaver-finetune
MLFLOW_MODEL_NAME=weaver-qwen
TRAIN_COMPAT_ACK=0
