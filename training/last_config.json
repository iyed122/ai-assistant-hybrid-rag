{
  "base_model": "unsloth/Qwen2.5-3B-Instruct-bnb-4bit",
  "method": "qlora",
  "lora_rank": 1,
  "lora_alpha": 3,
  "lora_dropout": 0.05,
  "lora_target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "epochs": 1,
  "batch_size": 1,
  "gradient_accumulation": 1,
  "learning_rate": 0.0002,
  "lr_scheduler": "cosine",
  "warmup_ratio": 0.05,
  "max_seq_length": 102,
  "weight_decay": 0.01,
  "max_grad_norm": 1.0,
  "dpo_beta": 0.1,
  "eval_strategy": "epoch",
  "eval_split": 0.15,
  "fp16": true,
  "bf16": false,
  "gradient_checkpointing": true,
  "optim": "paged_adamw_8bit",
  "output_dir": "C:\\Users\\iyedm\\Desktop\\AI Assistant\\training\\checkpoints",
  "run_name": ""
